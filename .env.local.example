# Amazon OpenSearch Service endpoint (without trailing slash)
OPENSEARCH_ENDPOINT=https://your-domain.us-east-1.es.amazonaws.com

# Authentication: choose one approach

# Option 1: Basic auth (for development / fine-grained access control)
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=your-password

# Option 2: AWS IAM (for production with OIDC federation or IAM roles)
# Leave USERNAME/PASSWORD empty and set these:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1

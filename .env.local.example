# Run `vercel env pull .env.local` after linking — this populates
# VERCEL_OIDC_TOKEN (used to exchange for short-lived AWS credentials
# via STS AssumeRoleWithWebIdentity) along with the values below.

# IAM role for the app to assume via Vercel OIDC.
# The role's trust policy must allow Vercel's OIDC issuer
# (https://oidc.vercel.com/<team-slug>) and grant
# aoss:APIAccessAll on your collections.
AWS_ROLE_ARN=arn:aws:iam::000000000000:role/your-vercel-oidc-role

# Region (override only if your collections aren't in us-east-1)
AWS_REGION=us-east-1

# Search Collection (keyword search)
OPENSEARCH_ENDPOINT=https://your-search-collection.us-east-1.aoss.amazonaws.com

# Vector Collection (semantic/k-NN search)
VECTOR_OPENSEARCH_ENDPOINT=https://your-vector-collection.us-east-1.aoss.amazonaws.com
